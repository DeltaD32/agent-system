# =============================================================================
# AI Agent System — Environment Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=agentuser
POSTGRES_PASSWORD=agentpass
POSTGRES_DB=agent_db

# --- RabbitMQ ---
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

# --- Grafana ---
GRAFANA_ADMIN_PASSWORD=admin

# --- Ollama / Local GPU ---
# Linux (Fedora): use the Docker bridge IP or host network
#   Run: ip route | awk '/default/ { print $3 }' to find your gateway
#   Example: OLLAMA_LOCAL_URL=http://172.17.0.1:11434
# macOS / Windows: use host.docker.internal
#   Example: OLLAMA_LOCAL_URL=http://host.docker.internal:11434
OLLAMA_LOCAL_URL=http://host.docker.internal:11434

# Default Ollama model to use (must be pulled: `ollama pull llama3`)
LOCAL_MODEL=llama3

# --- LAN GPU Server (optional second Ollama instance) ---
# Set to the IP of your second machine, leave blank to disable.
# Example: OLLAMA_REMOTE_URL=http://192.168.1.50:11434
OLLAMA_REMOTE_URL=

# --- Claude API (optional) ---
# Get your key from https://console.anthropic.com
# Leave blank to use local Ollama only.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# --- Obsidian Vault ---
# Path to your Obsidian vault directory on the HOST machine.
# Linux : OBSIDIAN_VAULT_PATH=/home/yourname/Documents/MyVault
# macOS : OBSIDIAN_VAULT_PATH=/Users/yourname/Documents/MyVault
# Windows (use forward slashes): OBSIDIAN_VAULT_PATH=C:/Users/yourname/Documents/MyVault
OBSIDIAN_VAULT_PATH=./data/vault
